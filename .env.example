# Port the WebSocket server listens on (ngrok tunnels to this).
PORT=

# OpenAI — the bring-your-own LLM driving the call.
AI_GATEWAY_API_KEY=

# The signing secret shown once when you enable Self-Hosted in Dial. Used to
# verify the X-Dial-Signature header on every incoming connection.
DIAL_SIGNING_SECRET=

DIAL_API_KEY=
